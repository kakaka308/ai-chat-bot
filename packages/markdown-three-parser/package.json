{
  "name": "markdown-three-parser",
  "version": "1.0.0",
  "description": "A parser for 3D markdown with math support",
  "type": "module",
  "main": "dist/markdown-three-parser.umd.js",
  "module": "dist/markdown-three-parser.es.js",
  "exports": {
    ".": {
      "import": "./dist/markdown-three-parser.es.js",
      "require": "./dist/markdown-three-parser.umd.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest --config vitest.config.js",
    "test:coverage": "vitest run --config vitest.config.js --coverage"
  },
  "keywords": ["markdown", "parser", "3d", "math"],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "dependencies": {
    "katex": "^0.16.22",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "vitest": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9"
  }
}